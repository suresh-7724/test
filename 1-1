# 5. Write a NumPy program to create an element-wise comparison (greater, greater_equal, less and less_equal) of two given arrays.
arr1 = np.array([1, 2, 3, 4])
arr2 = np.array([4, 3, 2, 1])

# Element-wise comparison
greater = np.greater(arr1, arr2)
greater_equal = np.greater_equal(arr1, arr2)
less = np.less(arr1, arr2)
less_equal = np.less_equal(arr1, arr2)

print("Greater:", greater)
print("Greater or Equal:", greater_equal)
print("Less:", less)
print("Less or Equal:", less_equal)


