# 15. Write a Pandas program to get the day of month, day of year, week number and day of week from a given series of date strings.
date_strings = pd.Series(['2024-12-01', '2024-12-02', '2024-12-03'])

# Convert string to datetime
dates = pd.to_datetime(date_strings)

# Extract day of month, day of year, week number and day of week
day_of_month = dates.dt.day
day_of_year = dates.dt.dayofyear
week_number = dates.dt.week
day_of_week = dates.dt.weekday

print("Day of Month:\n", day_of_month)
print("Day of Year:\n", day_of_year)
print("Week Number:\n", week_number)
print("Day of Week:\n", day_of_week)


# 16. Write a Pandas program to convert the first and last character of each word to uppercase in each word of a given series.
words = pd.Series(['hello', 'world', 'pandas'])

# Convert the first and last character of each word to uppercase
modified_words = words.apply(lambda x: x[0].upper() + x[1:-1] + x[-1].upper())

print("Modified Words:\n", modified_words)
