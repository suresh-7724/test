import pandas as pd
from mlxtend.frequent_patterns import apriori, association_rules

file_path = "groceries.csv"
data = pd.read_csv(file_path)

print("Dataset Preview:")
print(data.head())

data = data.stack().reset_index()
data.columns = ["Transaction", "Item", "Value"]
data = pd.crosstab(data["Transaction"], data["Item"])

frequent_itemsets = apriori(data, min_support=0.004, use_colnames=True)

rules = association_rules(frequent_itemsets, metric="lift", min_threshold=3)

filtered_rules = rules[
    (rules["confidence"] >= 0.2) &
    (rules["lift"] >= 3) &
    (rules["antecedents"].apply(len) >= 2)
]

print("\nSupport and Confidence for Each Rule:")
print(rules[["antecedents", "consequents", "support", "confidence"]])

print("\nFiltered Rules (Support >= 0.004, Confidence >= 0.2, Lift >= 3):")
print(filtered_rules[["antecedents", "consequents", "support", "confidence", "lift"]])
