class Graph:
    def __init__(self):
        self.graph = {}
        self.heuristics = {}
        self.solution = {}

    def add_node(self, node, children=None, heuristic=0):
        self.graph[node] = children or []
        self.heuristics[node] = heuristic

    def ao_star(self, node, backtracking=False):
        if node not in self.graph or not self.graph[node]:
            self.solution[node] = True
            return self.heuristics[node]

        if backtracking:
            solved = all(self.solution.get(child, False) for children in self.graph[node] for child in children)
            if solved:
                self.solution[node] = True
                return self.heuristics[node]

        min_cost = float('inf')
        best_children = None

        for children in self.graph[node]:
            cost = sum(self.heuristics[child] for child in children)
            if cost < min_cost:
                min_cost = cost
                best_children = children

        self.heuristics[node] = min_cost
        for child in best_children:
            self.ao_star(child)

        self.solution[node] = True
        return self.heuristics[node]

    def get_solution(self, start_node):
        self.ao_star(start_node, backtracking=True)
        solution_path = []
        node = start_node
        while node in self.solution:
            solution_path.append(node)
            children = self.graph.get(node)
            if not children:
                break
            best_children = min(children, key=lambda c: sum(self.heuristics[child] for child in c))
            node = best_children[0]
        return solution_path


graph = Graph()

graph.add_node('A', [['B', 'C'], ['D']], heuristic=0)
graph.add_node('B', [['E'], ['F']], heuristic=2)
graph.add_node('C', [], heuristic=2)
graph.add_node('D', [['G']], heuristic=4)
graph.add_node('E', [], heuristic=1)
graph.add_node('F', [], heuristic=2)
graph.add_node('G', [], heuristic=3)

start_node = 'A'
optimal_path = graph.get_solution(start_node)
print("Optimal Solution Path:", optimal_path)
