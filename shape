import pandas as pd

# Load the dataset
file_path = "Students Performance.csv"  # Replace with your file path
data = pd.read_csv(file_path)

# a. Display the shape of the dataset
print("Shape of the dataset:", data.shape)

# b. Display the top rows of the dataset with their columns
print("\nTop rows of the dataset:")
print(data.head())

# c. Display a random sample of rows
num_random_rows = 5  # Change the number of rows as needed
print(f"\n{num_random_rows} randomly selected rows:")
print(data.sample(num_random_rows))

# d. Display the number of columns and names of the columns
print("\nNumber of columns:", len(data.columns))
print("Names of the columns:")
print(data.columns.tolist())
